# ===========================================
# Chrononaut Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# -------------------------------------------
# Supabase (required)
# -------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------
# Site URL (required)
# -------------------------------------------
# Used for OAuth redirect URIs and absolute URLs.
# Local development: http://localhost:3000
# Production: your deployed URL (e.g., https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------
# Anthropic / AI (required for AI features)
# -------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------
# Google Calendar Integration (optional)
# -------------------------------------------
# Set up a Google Cloud project:
# 1. Enable Google Calendar API
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add redirect URI: {NEXT_PUBLIC_SITE_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# -------------------------------------------
# Whoop Integration (optional)
# -------------------------------------------
# Register at: https://developer.whoop.com
# Add redirect URI: {NEXT_PUBLIC_SITE_URL}/api/integrations/whoop/callback
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# -------------------------------------------
# Deepgram Transcription (optional)
# -------------------------------------------
# Sign up at: https://deepgram.com
# Get API key from: https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# -------------------------------------------
# Cron Job Secret (optional)
# -------------------------------------------
# Protects cron API routes from unauthorized access.
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# -------------------------------------------
# Vercel (auto-set by Vercel, optional locally)
# -------------------------------------------
# VERCEL_URL is automatically set by Vercel during deployment.
# You typically don't need to set this locally.
# VERCEL_URL=your-app.vercel.app
