# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# electron
/dist-electron

# supabase local state (contains project-specific refs)
supabase/.temp/

# misc
.DS_Store
*.pem

# Claude Code
.claude/settings.local.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# MCP configuration (contains sensitive tokens)
.cursor/mcp.json
.mcp.json

# Backup files (stored in separate repo)
/backups
/backup-repo
